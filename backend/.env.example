# Environment Configuration - AI Customer Service Agent
# Copy file này thành .env và điền thông tin của bạn

# ─── Database ──────────────────────────────────────────
# Mặc định dùng SQLite (không cần cài thêm gì)
DATABASE_URL=sqlite:///./cs_agent.db

# PostgreSQL (nếu muốn dùng thay SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/cs_agent

# ─── Redis (tùy chọn - cho cache và queue) ──────────────
REDIS_URL=redis://localhost:6379

# ─── OpenAI (AI Engine) ────────────────────────────────
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
MULTI_AGENT_ENABLED=true

# ─── Frontend ──────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Facebook Messenger ────────────────────────────────
# Lấy tại: https://developers.facebook.com/
FACEBOOK_PAGE_TOKEN=your-facebook-page-access-token
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_VERIFY_TOKEN=silence_verify_2024

# ─── Instagram (dùng chung Meta API) ───────────────────
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token

# ─── Shopee Open Platform (mock trong MVP) ──────────────
# Đăng ký tại: https://open.shopee.com/
SHOPEE_PARTNER_ID=your-shopee-partner-id
SHOPEE_PARTNER_KEY=your-shopee-partner-key

# ─── TikTok for Business (mock trong MVP) ───────────────
# Đăng ký tại: https://developers.tiktok.com/
TIKTOK_APP_KEY=your-tiktok-app-key
TIKTOK_APP_SECRET=your-tiktok-app-secret

# ─── Security ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-in-production
DEBUG=true
